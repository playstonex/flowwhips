{
  "expo": {
    "name": "Baton",
    "slug": "baton",
    "version": "0.0.1",
    "orientation": "default",
    "scheme": "baton",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.playstone.baton"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.playstone.baton"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "21da053a-4ea2-4a49-809a-f6e8ef8f7a21"
      }
    },
    "owner": "playstone"
  }
}
